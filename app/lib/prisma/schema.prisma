generator client {
  provider = "prisma-client"
  output   = "./generated"
  runtime  = "vercel-edge"
}

datasource db {
  provider = "postgresql"
}

enum StatusLeitura {
  LIDO
  LENDO
  QUERO_LER
  ABANDONEI
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id             String    @id @default(cuid())
  nome           String
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  foto           String
  bio            String
  role           String    @default("user")
  senha          String
  username       String    @unique
  dataNascimento DateTime?

  accounts      Account[]
  sessions      Session[]

  amizadesIniciadas Amigos[]     @relation("Amigo1")
  amizadesRecebidas Amigos[]     @relation("Amigo2")
  postagens         Postagem[]   
  comentarios       Comentario[]
  bibliotecas       Biblioteca[]
  curtidas          Curtida[]

  @@map("usuarios")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Livro {
  id              Int           @id @default(autoincrement())
  titulo          String
  ano             Int
  genero          String
  paginas         Int
  capa            String
  createdAt       DateTime      @default(now())
  sinopse         String
  colecaoId       Int?
  posicao_colecao Float?

  colecao     Colecao?      @relation(fields: [colecaoId], references: [id])
  autores     Escrito_por[]
  postagens   Postagem[]
  bibliotecas Biblioteca[]

  @@unique([colecaoId, posicao_colecao])
  @@map("livros")
}

model Colecao {
  id     Int     @id @default(autoincrement())
  nome   String
  livros Livro[]

  @@map("colecao")
}

model Autor {
  id     Int           @id @default(autoincrement())
  nome   String
  livros Escrito_por[]

  @@map("autor")
}

model Escrito_por {
  livroId Int
  autorId Int
  autor   Autor @relation(fields: [autorId], references: [id], onDelete: Cascade)
  livro   Livro @relation(fields: [livroId], references: [id], onDelete: Cascade)

  @@id([livroId, autorId])
  @@map("escrito_por")
}

model Postagem {
  id           Int      @id @default(autoincrement())
  paginaAtual  Int?
  paginasLidas Int?
  nota         Int?
  data         DateTime
  titulo       String?
  texto        String
  temSpoiler   Boolean?

  usuarioId String @map("usuario_id")
  livroId   Int    @map("livro_id")

  usuario     User         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  livro       Livro        @relation(fields: [livroId],   references: [id], onDelete: Cascade)

  comentarios Comentario[]
  curtidas    Curtida[]

  @@map("postagens")
}

model Comentario {
  id         Int      @id @default(autoincrement())
  data       DateTime
  texto      String

  usuarioId  String @map("usuario_id")
  postagemId Int    @map("postagem_id")
  parentId   Int?   @map("parent_id")

  usuario   User         @relation(fields: [usuarioId],  references: [id], onDelete: Cascade)
  postagem  Postagem     @relation(fields: [postagemId], references: [id], onDelete: Cascade)

  parent    Comentario?  @relation("RespostasComent", fields: [parentId], references: [id], onDelete: SetNull)
  respostas Comentario[] @relation("RespostasComent")
  curtidas  Curtida[]

  @@map("comentarios")
}

model Biblioteca {
  usuarioId String @map("usuario_id")
  livroId   Int    @map("livro_id")

  status        StatusLeitura
  dataInicio    DateTime?  @map("data_inicio")
  dataConclusao DateTime? @map("data_conclusao")

  usuario User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  livro   Livro @relation(fields: [livroId],   references: [id], onDelete: Cascade)

  @@id([usuarioId, livroId])
  @@map("biblioteca")
}

model Curtida {
  id Int @id @default(autoincrement())

  usuarioId    String @map("usuario_id")
  postagemId   Int?   @map("postagem_id")
  comentarioId Int?   @map("comentario_id")

  usuario    User        @relation(fields: [usuarioId],    references: [id], onDelete: Cascade)
  postagem   Postagem?   @relation(fields: [postagemId],   references: [id], onDelete: Cascade)
  comentario Comentario? @relation(fields: [comentarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, comentarioId])
  @@unique([usuarioId, postagemId])

  @@map("curtidas")
}

model Amigos {
  amigo1Id String @map("amigo1_id")
  amigo2Id String @map("amigo2_id")

  amigo1 User @relation("Amigo1", fields: [amigo1Id], references: [id], onDelete: Cascade)
  amigo2 User @relation("Amigo2", fields: [amigo2Id], references: [id], onDelete: Cascade)

  @@id([amigo1Id, amigo2Id])
  @@map("amigos")
}