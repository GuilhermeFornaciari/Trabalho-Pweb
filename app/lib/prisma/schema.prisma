generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
  foto  String

  @@map("usuarios")
}

model Livro {
  id              Int           @id @default(autoincrement())
  titulo          String
  ano             Int
  genero          String
  paginas         Int
  capa            String
  createdAt       DateTime      @default(now())
  sinopse         String
  colecaoId       Int?
  posicao_colecao Float?
  autores         Escrito_por[]
  colecao         Colecao?      @relation(fields: [colecaoId], references: [id])

  @@unique([colecaoId, posicao_colecao])
  @@map("livros")
}

model Colecao {
  id     Int     @id @default(autoincrement())
  nome   String
  livros Livro[]

  @@map("colecao")
}

model Autor {
  id     Int           @id @default(autoincrement())
  nome   String
  livros Escrito_por[]

  @@map("autor")
}

model Escrito_por {
  livroId Int
  autorId Int
  autor   Autor @relation(fields: [autorId], references: [id], onDelete: Cascade)
  livro   Livro @relation(fields: [livroId], references: [id], onDelete: Cascade)

  @@id([livroId, autorId])
  @@map("escrito_por")
}
