generator client {
  provider = "prisma-client"
  output   = "./generated"
  runtime  = "vercel-edge"
}

datasource db {
  provider = "postgresql"
}

model Account { 
  id                String  @id @default(cuid()) 
  userId            String  @map("user_id") 
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id") 
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade) 
  @@unique([provider, providerAccountId]) 
  @@map("accounts") 
} 

model Session { 
  id           String   @id @default(cuid()) 
  sessionToken String   @unique @map("session_token") 
  userId       String   @map("user_id") 
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  @@map("sessions") 
} 

model User { 
  id            String    @id @default(cuid()) 
  name          String
  email         String   @unique
  emailVerified DateTime? @map("email_verified") 
  foto          String
  role          String
  username      String   @unique
  dataNascimento DateTime
  accounts      Account[]
  sessions      Session[]

  @@map("usuarios") 
} 

model VerificationToken { 
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token]) 
  @@map("verification_tokens") 
} 

model Livro {
  id              Int           @id @default(autoincrement())
  titulo          String
  ano             Int
  genero          String
  paginas         Int
  capa            String
  createdAt       DateTime      @default(now())
  sinopse         String
  colecaoId       Int?
  posicao_colecao Float?
  autores         Escrito_por[]
  colecao         Colecao?      @relation(fields: [colecaoId], references: [id])

  @@unique([colecaoId, posicao_colecao])
  @@map("livros")
}

model Colecao {
  id     Int     @id @default(autoincrement())
  nome   String
  livros Livro[]

  @@map("colecao")
}

model Autor {
  id     Int           @id @default(autoincrement())
  nome   String
  livros Escrito_por[]

  @@map("autor")
}

model Escrito_por {
  livroId Int
  autorId Int
  autor   Autor @relation(fields: [autorId], references: [id], onDelete: Cascade)
  livro   Livro @relation(fields: [livroId], references: [id], onDelete: Cascade)

  @@id([livroId, autorId])
  @@map("escrito_por")
}
