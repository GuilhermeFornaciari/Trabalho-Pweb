generator client {
  provider = "prisma-client"
  output   = "./generated"
  runtime  = "vercel-edge"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                String       @id @default(cuid())
  nome              String
  email             String       @unique
  emailVerified     DateTime?    @map("email_verified")
  foto              String
  bio               String
  role              String       @default("user")
  senha             String
  username          String       @unique
  dataNascimento    DateTime?
  accounts          Account[]
  amizadesIniciadas Amigos[]     @relation("Amigo1")
  amizadesRecebidas Amigos[]     @relation("Amigo2")
  biblioteca        Biblioteca[]
  comentarios       Comentario[]
  curtidas          Curtida[]
  postagens         Postagem[]
  sessions          Session[]

  @@map("usuarios")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Livro {
  id              Int           @id @default(autoincrement())
  titulo          String
  ano             Int
  genero          String
  paginas         Int
  capa            String
  createdAt       DateTime      @default(now())
  sinopse         String
  colecaoId       Int?
  posicao_colecao Float?
  bibliotecas     Biblioteca[]
  autores         Escrito_por[]
  colecao         Colecao?      @relation(fields: [colecaoId], references: [id])
  postagens       Postagem[]

  @@unique([colecaoId, posicao_colecao])
  @@map("livros")
}

model Colecao {
  id     Int     @id @default(autoincrement())
  nome   String
  livros Livro[]

  @@map("colecao")
}

model Autor {
  id     Int           @id @default(autoincrement())
  nome   String
  livros Escrito_por[]

  @@map("autor")
}

model Escrito_por {
  livroId Int
  autorId Int
  autor   Autor @relation(fields: [autorId], references: [id], onDelete: Cascade)
  livro   Livro @relation(fields: [livroId], references: [id], onDelete: Cascade)

  @@id([livroId, autorId])
  @@map("escrito_por")
}

model Postagem {
  id           Int          @id @default(autoincrement())
  paginaAtual  Int?
  paginasLidas Int?
  nota         Int?
  data         DateTime     @default(now())
  texto        String?
  temSpoiler   Boolean?
  usuarioId    String       @map("usuario_id")
  livroId      Int          @map("livro_id")
  titulo       String?
  comentarios  Comentario[]
  curtidas     Curtida[]
  livro        Livro        @relation(fields: [livroId], references: [id], onDelete: Cascade)
  usuario      User         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([data])
  @@index([usuarioId])
  @@index([livroId])
  @@index([livroId, data])

  @@map("postagens")
}

model Comentario {
  id         Int          @id @default(autoincrement())
  data       DateTime
  texto      String
  usuarioId  String       @map("usuario_id")
  postagemId Int          @map("postagem_id")
  parentId   Int?         @map("parent_id")
  parent     Comentario?  @relation("RespostasComent", fields: [parentId], references: [id])
  respostas  Comentario[] @relation("RespostasComent")
  postagem   Postagem     @relation(fields: [postagemId], references: [id], onDelete: Cascade)
  usuario    User         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  curtidas   Curtida[]

  @@index([postagemId, data])
  @@index([usuarioId])
  @@index([parentId])

  @@map("comentarios")
}

model Biblioteca {
  usuarioId     String        @map("usuario_id")
  livroId       Int           @map("livro_id")
  dataInicio    DateTime?     @map("data_inicio")
  dataConclusao DateTime?     @map("data_conclusao")
  nota          Int?
  paginaAtual   Int?         
  status        StatusLeitura
  livro         Livro         @relation(fields: [livroId], references: [id], onDelete: Cascade)
  usuario       User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([usuarioId, livroId])
  @@map("biblioteca")
}

model Curtida {
  id           Int         @id @default(autoincrement())
  usuarioId    String      @map("usuario_id")
  postagemId   Int?        @map("postagem_id")
  comentarioId Int?        @map("comentario_id")
  comentario   Comentario? @relation(fields: [comentarioId], references: [id], onDelete: Cascade)
  postagem     Postagem?   @relation(fields: [postagemId], references: [id], onDelete: Cascade)
  usuario      User        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, comentarioId])
  @@unique([usuarioId, postagemId])

  @@index([postagemId])
  @@index([comentarioId])
  
  @@map("curtidas")
}

model Amigos {
  amigo1Id String @map("amigo1_id")
  amigo2Id String @map("amigo2_id")
  amigo1   User   @relation("Amigo1", fields: [amigo1Id], references: [id], onDelete: Cascade)
  amigo2   User   @relation("Amigo2", fields: [amigo2Id], references: [id], onDelete: Cascade)

  @@id([amigo1Id, amigo2Id])
  @@map("amigos")
}

enum StatusLeitura {
  LIDO
  LENDO
  QUERO_LER
  ABANDONEI
}
